{
  "io": {
    "training_folder": "./dst/training",
    "validation_folder": "./dst/validation",
    "test_folder": "./dst/test",
    "use_custom_dataset": false,
    "out_folder": "./out"
  },
  "parameters": {
    "train": true,
    "test": true,
    "show_preview": true
  },
  "hyper_parameters": {
    "batch_size": 3,
    "epochs": 10,
    "learning_rate": 0.0004,
    "momentum": 0.9
  },
  "train_parameters": {
    "network_type": "net_4",
    "console_log_steps": 5,
    "metrics_computation_steps": 32,
    "target": 95,
    "target_evaluation_steps": 32,
    "reload_last_model": false
  },
  "early_stop_parameters": {
    "es_check_steps": 32,
    "es_start_at_step": 256,
    "patience": 5,
    "improvement_rate": 5
  }
}
